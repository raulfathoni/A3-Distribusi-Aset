<!doctype html>
<html lang="en">
<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) {}
    })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Distribusi Aset FTI</title>
  <link rel="stylesheet" href="/assets/styles.css" />
  <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
</head>
<body class="bg-background">
  <%- include('partials/sidebar', { activeTab: 'assets' }) %>
  <div class="p-6">
    <div class="max-w-screen-md mx-auto">

      <div class="flex items-center gap-4 mb-6">
        <a href="/assets" class="btn-outline">← Kembali</a>
        <h1 class="text-2xl font-bold">Distribusi Aset FTI</h1>
      </div>

      <div class="card">
        <header>
          <h2><%= asset.name %></h2>
          <p class="text-muted-foreground"><%= asset.code %></p>
        </header>
        <section class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-sm text-muted-foreground">Tipe</p>
            <p class="font-medium">
              <%= asset.type === 'equipment' ? 'Peralatan' : asset.type === 'room' ? 'Ruangan' : '-' %>
            </p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground">Status</p>
            <p class="font-medium">
              <%= asset.status === 'available' ? 'Tersedia' : asset.status === 'in_use' ? 'Digunakan' : asset.status === 'maintenance' ? 'Dalam Perawatan' : 'Tidak Aktif' %>
            </p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground">Kondisi</p>
            <p class="font-medium">
              <%= asset.condition === 'good' ? 'Baik' : asset.condition === 'minor_damage' ? 'Rusak Ringan' : asset.condition === 'major_damage' ? 'Rusak Berat' : '-' %>
            </p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground">Tanggal Perolehan</p>
            <p class="font-medium"><%= asset.acquisition_date ? new Date(asset.acquisition_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) : '-' %></p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground">Brand</p>
            <p class="font-medium"><%= asset.brand || '-' %></p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground">Model</p>
            <p class="font-medium"><%= asset.model || '-' %></p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground">Serial Number</p>
            <p class="font-medium"><%= asset.serial_number || '-' %></p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground">Spesifikasi</p>
            <p class="font-medium"><%= asset.specification || '-' %></p>
          </div>
        </section>
      </div>

      <!-- Active Distribution / Allocation Form -->
      <div class="mt-6">
        <% if (currentDistribution && currentDistribution.status === 'pending') { %>
          <div class="card border-warning/50 bg-warning/5">
            <header class="flex justify-between items-center mb-4">
              <div>
                <h2 class="text-lg font-bold">Alokasi Tertunda (Menunggu BAST)</h2>
                <p class="text-sm text-muted-foreground">Aset ini telah dialokasikan, silakan cetak BAST lalu unggah berkas yang ditandatangani.</p>
              </div>
            </header>
            <section class="grid grid-cols-2 gap-4 mb-6">
              <div>
                <p class="text-sm text-muted-foreground">Calon Penerima</p>
                <p class="font-medium"><%= currentDistribution.recipient_name %></p>
              </div>
              <div>
                <p class="text-sm text-muted-foreground">Tanggal Alokasi</p>
                <p class="font-medium">
                  <%= currentDistribution.distribution_date ? new Date(currentDistribution.distribution_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) : '-' %>
                </p>
              </div>
              <div class="col-span-2">
                <p class="text-sm text-muted-foreground">Catatan / Keterangan</p>
                <p class="font-medium"><%= currentDistribution.notes || '-' %></p>
              </div>
            </section>

            <div class="flex flex-col gap-4 border-t pt-4">
              <div>
                <h3 class="text-sm font-semibold mb-2">Langkah 1: Cetak Form BAST</h3>
                <a href="/assets/distributions/print/<%= currentDistribution.id %>" target="_blank" class="btn w-full flex items-center justify-center gap-2" style="background-color: white; color: black; border: 1px solid #e2e8f0; font-weight: 600;">
                  🖨️ Cetak Form BAST (Pre-filled)
                </a>
              </div>

              <div>
                <h3 class="text-sm font-semibold mb-2">Langkah 2: Unggah Form BAST yang Sudah Ditandatangani</h3>
                <form action="/assets/detail/<%= asset.id %>/upload-bast" method="POST" enctype="multipart/form-data" class="flex flex-col gap-3">
                  <input type="file" name="bast_file" id="bast_file" class="input w-full" accept=".pdf,.png,.jpg,.jpeg,.doc,.docx" required style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #ccc;" />
                  <button type="submit" class="btn w-full" style="background-color: white; color: black; border: 1px solid #e2e8f0; font-weight: 600;">Unggah & Aktifkan Distribusi</button>
                </form>
              </div>

              <div class="border-t pt-4">
                <form action="/assets/distributions/cancel/<%= currentDistribution.id %>" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin membatalkan alokasi pending ini?')">
                   <button type="submit" class="btn-outline w-full" style="color: #ef4444; border-color: #ef4444;">
                    ✕ Batalkan Alokasi
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% } else if (asset.status === 'in_use' && currentDistribution) { %>
          <div class="card">
            <header class="flex justify-between items-center mb-4">
              <div>
                <h2 class="text-lg font-bold">Informasi Distribusi Aktif</h2>
                <p class="text-sm text-muted-foreground">Aset ini sedang digunakan (Terdistribusi)</p>
              </div>
              <div class="flex gap-2">
                 <a href="/assets/distributions/print/<%= currentDistribution.id %>" target="_blank" class="btn-sm-outline">
                  🖨️ Cetak BAST
                </a>
              </div>
            </header>
            <section class="grid grid-cols-2 gap-4 mb-2">
              <div>
                <p class="text-sm text-muted-foreground">Penanggung Jawab / Penerima</p>
                <p class="font-medium"><%= currentDistribution.recipient_name %></p>
              </div>
              <div>
                <p class="text-sm text-muted-foreground">Tanggal Penyerahan</p>
                <p class="font-medium">
                  <%= currentDistribution.distribution_date ? new Date(currentDistribution.distribution_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) : '-' %>
                </p>
              </div>
              <div class="col-span-2">
                <p class="text-sm text-muted-foreground">Catatan / Kondisi Serah Terima</p>
                <p class="font-medium"><%= currentDistribution.notes || '-' %></p>
              </div>
              <div class="col-span-2">
                <p class="text-sm text-muted-foreground">Dokumen BAST</p>
                <% if (currentDistribution.bast_file_path) { %>
                  <a href="<%= currentDistribution.bast_file_path %>" target="_blank" class="text-primary hover:underline font-medium inline-flex items-center gap-1">
                    📄 Lihat Dokumen BAST
                  </a>
                <% } else { %>
                  <p class="text-muted-foreground text-sm italic">Belum ada dokumen BAST yang diunggah</p>
                <% } %>
              </div>
            </section>
          </div>

          <div class="card mt-6">
            <header class="mb-4">
              <h2 class="text-lg font-bold">Form Pengembalian Aset</h2>
              <p class="text-sm text-muted-foreground">Catat tanggal dan kondisi aset saat dikembalikan</p>
            </header>
            <form action="/assets/distributions/return/<%= currentDistribution.id %>" method="POST" class="flex flex-col gap-4" onsubmit="return confirm('Apakah Anda yakin ingin mengembalikan aset ini?')">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="label mb-1 text-xs" for="return_date">Tanggal Pengembalian</label>
                  <input type="date" name="return_date" id="return_date" class="input w-full" value="<%= new Date().toISOString().split('T')[0] %>" required style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #ccc;" />
                </div>
                <div>
                  <label class="label mb-1 text-xs" for="return_notes">Catatan Kondisi Pengembalian (Opsional)</label>
                  <textarea name="return_notes" id="return_notes" class="input w-full" placeholder="Keterangan kondisi aset saat dikembalikan..." style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #ccc; height: 38px; min-height: 38px; resize: none;"></textarea>
                </div>
              </div>
              <button type="submit" class="btn w-full bg-destructive text-destructive-foreground hover:bg-destructive/90 mt-2" style="background-color: #ef4444; color: white;">
                Konfirmasi Pengembalian Aset
              </button>
            </form>
          </div>
        <% } else if (asset.status === 'available') { %>
          <div class="card">
            <header class="mb-4">
              <h2 class="text-lg font-bold">Alokasikan Aset</h2>
              <p class="text-sm text-muted-foreground">Mulai alur penyerahan aset ke personel tertentu</p>
            </header>
            
            <form action="/assets/detail/<%= asset.id %>/allocate" method="POST" class="flex flex-col gap-4">
              <div>
                <label class="label mb-1" for="recipient_id">Penerima Aset (Personel)</label>
                <select name="recipient_id" id="recipient_id" class="select w-full" required style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #ccc;">
                  <option value="">Pilih Penerima...</option>
                  <% recipients.forEach(rec => { %>
                     <option value="<%= rec.id %>"><%= rec.name %></option>
                  <% }) %>
                </select>
              </div>
              
              <div>
                <label class="label mb-1" for="distribution_date">Tanggal Alokasi</label>
                <input type="date" name="distribution_date" id="distribution_date" class="input w-full" value="<%= new Date().toISOString().split('T')[0] %>" required style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #ccc;" />
              </div>
              
              <div>
                <label class="label mb-1" for="notes">Catatan Kondisi / Keterangan</label>
                <textarea name="notes" id="notes" class="input w-full min-h-[80px]" placeholder="Masukkan catatan kondisi penyerahan aset..." style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #ccc; min-height: 80px;"></textarea>
              </div>
              
              <button type="submit" class="btn w-full mt-2" style="background-color: white; color: black; border: 1px solid #e2e8f0; font-weight: 600;">Buat Alokasi & Cetak BAST</button>
            </form>
          </div>
        <% } else { %>
          <div class="card bg-muted/30">
            <p class="text-center text-muted-foreground p-4">
              Aset ini berstatus <strong><%= asset.status === 'maintenance' ? 'Dalam Perawatan' : 'Tidak Aktif' %></strong> dan tidak dapat dialokasikan saat ini.
            </p>
          </div>
        <% } %>
      </div>

      <!-- History card -->
      <div class="card mt-6">
        <header class="mb-4">
          <h2 class="text-lg font-bold">Riwayat Distribusi</h2>
          <p class="text-sm text-muted-foreground">Riwayat penyerahan dan pengembalian aset</p>
        </header>
        
        <% if (distributionHistory.length === 0) { %>
          <p class="text-center text-muted-foreground py-6">Belum ada riwayat distribusi untuk aset ini.</p>
        <% } else { %>
          <div class="overflow-x-auto w-full">
          <table class="table">
            <thead>
              <tr>
                <th>Penerima</th>
                <th>Tanggal Diserahkan</th>
                <th>Tanggal Dikembalikan</th>
                <th>Status</th>
                <th>Catatan</th>
                <th>BAST</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% distributionHistory.forEach(hist => { %>
                <tr>
                   <td>
                     <div class="font-medium"><%= hist.recipient_name %></div>
                   </td>
                  <td>
                    <%= hist.distribution_date ? new Date(hist.distribution_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %>
                  </td>
                  <td>
                    <% if (hist.status === 'returned') { %>
                      <%= hist.return_date ? new Date(hist.return_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %>
                    <% } else if (hist.status === 'active') { %>
                      <span class="text-xs text-blue-500 font-medium">Sedang Digunakan</span>
                    <% } else { %>
                      <span class="text-xs text-muted-foreground">-</span>
                    <% } %>
                  </td>
                  <td>
                    <span class="badge <%= hist.status === 'pending' ? 'badge-warning' : hist.status === 'active' ? 'badge-info' : 'badge-success' %>">
                      <%= hist.status === 'pending' ? 'Menunggu BAST' : hist.status === 'active' ? 'Aktif' : 'Dikembalikan' %>
                    </span>
                  </td>
                  <td class="text-sm max-w-[200px] truncate" title="<%= hist.status === 'returned' && hist.return_notes ? hist.return_notes : (hist.notes || '-') %>">
                    <%= hist.status === 'returned' && hist.return_notes ? hist.return_notes : (hist.notes || '-') %>
                  </td>
                  <td>
                    <% if (hist.bast_file_path) { %>
                      <a href="<%= hist.bast_file_path %>" target="_blank" class="text-xs text-primary hover:underline">Download</a>
                    <% } else { %>
                      <span class="text-xs text-muted-foreground">-</span>
                    <% } %>
                  </td>
                  <td>
                     <a href="/assets/distributions/print/<%= hist.id %>" target="_blank" class="btn-sm-outline py-0.5 px-1.5 text-xs">
                       Cetak BAST
                     </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</body>
</html>